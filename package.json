{
  "name": "api-forge",
  "private": true,
  "version": "0.2.16",
  "license": "Apache-2.0",
  "description": "接口调试台桌面端 API 测试与调试工具",
  "author": {
    "name": "Code4Bug",
    "email": "113855503@qq.com"
  },
  "type": "module",
  "main": "dist-electron/electron/main/index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"vite --host 127.0.0.1 --port 5174\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5174 dist-electron/electron/main/index.js && node scripts/start-electron.mjs\" ",
    "dev:web": "vite",
    "build": "tsc -b && tsc -p tsconfig.electron.json && vite build",
    "lint": "eslint .",
    "test": "npm run check",
    "release:tag": "node scripts/release-tag.mjs",
    "preview": "vite preview",
    "check": "tsc -b --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:win:x64": "npm run build && electron-builder --win --x64 --publish never",
    "build:win:arm64": "npm run build && electron-builder --win --arm64 --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "build:linux:x64": "npm run build && electron-builder --linux --x64 --publish never",
    "build:linux:arm64": "npm run build && electron-builder --linux --arm64 --publish never",
    "build:all": "npm run build && electron-builder --mac --win --linux --publish never"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/trusted-types": "^2.0.7",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.6",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.api-test-tools.desktop",
    "productName": "API-forge",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Code4Bug",
      "repo": "api-forge"
    },
    "icon": "public/favicon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "src/skills/**/*",
      "package.json"
    ],
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "deb": {
        "afterInstall": "build/linux/deb-after-install.sh"
      },
      "category": "Utility"
    }
  }
}
